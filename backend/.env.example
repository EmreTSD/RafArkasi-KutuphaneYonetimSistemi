# ==========================================
# Raf Arkası - Sunucu Ortam Değişkenleri Şablonu (.env.example)
# ==========================================

# Sunucu Ayarları
PORT=5000
NODE_ENV=development

# ------------------------------------------
# PostgreSQL Veritabanı Ayarları (Supabase veya Yerel)
# ------------------------------------------

# Veritabanı URL'si (Örn: Supabase bağlantı adresi)
DATABASE_URL="postgresql://kullanici_adi:sifre@host:port/veritabanı_adı"

# Yerel Veritabanı kullanacaksanız (DATABASE_URL boş bırakılabilir):
VT_HOST=localhost
VT_PORT=5432
VT_AD=kutuphane_db
VT_KULLANICI=postgres
VT_SIFRE=sifreniz

# Bulut veritabanları için SSL genellikle gereklidir (true/false)
VT_SSL=true

# ------------------------------------------
# Güvenlik Ayarları (JWT)
# ------------------------------------------
JWT_GIZLI_ANAHTAR="sizin_cok_guclu_gizli_anahtariniz"
JWT_SURE="7d"
